# Agent configuration — copy to `.env` and fill in. NON-SECRET identifiers only.
# The real secrets (OpenAI key, Databricks client secret) are pulled from Azure
# Key Vault at runtime via DefaultAzureCredential — do NOT put them here.

# --- Databricks SQL warehouse (the agent queries gold through this) ---
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxxxxxx.x.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
DATABRICKS_CLIENT_ID=<databricks-service-principal-client-id>

# --- Azure Key Vault (source of the secrets above) ---
AZURE_KEY_VAULT_URL=https://<your-key-vault>.vault.azure.net/

# --- Unity Catalog identifiers (defaults shown; override only if different) ---
DATABRICKS_CATALOG=rl_dev
DATABRICKS_GOLD_SCHEMA=gold

# --- Optional local override (otherwise resolved from Key Vault) ---
# OPENAI_API_KEY=
